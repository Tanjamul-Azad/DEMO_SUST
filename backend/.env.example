# QueueStorm backend configuration. Copy to .env. NO SECRETS REQUIRED.
# The service is fully functional with the LLM disabled (rules engine only).

PORT=8787
DATABASE_URL=./queuestorm.db

# LLM is OPTIONAL. Ollama runs locally on CPU (no GPU, no API key, no secrets).
LLM_ENABLED=true
OLLAMA_HOST=http://localhost:11434
GEMMA_MODEL=gemma4
GEMMA_TIMEOUT_MS=6000

# CORS origin for the frontend dev server (use * to allow all in local dev)
CORS_ORIGIN=*
